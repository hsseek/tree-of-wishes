# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# A random secret for signing session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me

# Public URL of this server (no trailing slash).
# Used to build the Google OAuth redirect URI.
BASE_URL=https://your-domain.com

# Google OAuth — https://console.cloud.google.com/
# Authorized redirect URI to register: {BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Report / contact email — where user reports and suggestions are sent.
# SMTP_USER / SMTP_PASS are the sending account credentials (e.g. a Gmail app password).
# Leave all blank to disable the Report feature.
REPORT_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
